{
    "openapi": "3.0.0",
    "info": {
        "title": "My API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000/api",
            "description": "Local server"
        }
    ],
    "paths": {
        "/login": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "Login API",
                "operationId": "ced696ccaeb9e975516d841d4dd4e613",
                "parameters": [
                    {
                        "name": "Accept",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "application/json"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    }
                }
            }
        },
        "/register": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "Register API",
                "operationId": "e7f511768ce85bef438ffcddb6e1e762",
                "parameters": [
                    {
                        "name": "Accept",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "application/json"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Register successfully"
                    },
                    "400": {
                        "description": "Validation error"
                    },
                    "409": {
                        "description": "Email already exists"
                    }
                }
            }
        },
        "/token/refresh": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "Refresh token api",
                "operationId": "67d4707a910ef05a5a2ee4d340d52c8c",
                "parameters": [
                    {
                        "name": "X-Refresh-Token",
                        "in": "header",
                        "description": "Refresh token key",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "sucess"
                    },
                    "401": {
                        "description": "UnAuthenticated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/logout": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "Logout",
                "operationId": "5c4c17aef901550a51761c0d5e42941d",
                "parameters": [
                    {
                        "name": "X-Refresh-Token",
                        "in": "header",
                        "description": "Refresh Token key",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "logout successfuly"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/profile": {
            "get": {
                "tags": [
                    "AUTH"
                ],
                "summary": "Profile",
                "operationId": "d5890787953f56cc9df054fd574b7632",
                "responses": {
                    "200": {
                        "description": "Profile"
                    },
                    "401": {
                        "description": "Unauthorize"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/password_change": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "password resend link",
                "operationId": "e01ea3671eac0be18f60720cb7cf8758",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "404": {
                        "description": "email not found"
                    },
                    "200": {
                        "description": "email send successfully"
                    }
                }
            }
        },
        "/reset_password": {
            "post": {
                "tags": [
                    "AUTH"
                ],
                "summary": "PASSWORD RESET",
                "operationId": "efb4bd6f79fac2b0bb0e7254ee5ed0f3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "token",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "token": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "password_confirmation": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "password reset successfully"
                    }
                }
            }
        },
        "/super_admin/create_hotel": {
            "post": {
                "tags": [
                    "Hotel"
                ],
                "summary": "Create hotel",
                "operationId": "73b4f4c80433d56e12bfc01518cc54ae",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "phone",
                                    "address",
                                    "city",
                                    "state",
                                    "country",
                                    "postal_code"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "hotel_tag"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "tawheedyahya0@gmail.com"
                                    },
                                    "phone": {
                                        "type": "string"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Main Road"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Chennai"
                                    },
                                    "state": {
                                        "type": "string",
                                        "example": "Tamil Nadu"
                                    },
                                    "country": {
                                        "type": "string",
                                        "example": "India"
                                    },
                                    "postal_code": {
                                        "type": "string",
                                        "example": "600001"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "hotel created successfully"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/super_admin/update_hotel/{id}": {
            "put": {
                "tags": [
                    "Hotel"
                ],
                "summary": "Update hotel",
                "operationId": "e65ddb2f2f08dd7848a9f778e1c445f7",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "phone",
                                    "address",
                                    "city",
                                    "state",
                                    "country",
                                    "postal_code"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Hotel Taj"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "test@gmail.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "9876543210"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Main Road"
                                    },
                                    "city": {
                                        "type": "string",
                                        "example": "Chennai"
                                    },
                                    "state": {
                                        "type": "string",
                                        "example": "Tamil Nadu"
                                    },
                                    "country": {
                                        "type": "string",
                                        "example": "India"
                                    },
                                    "postal_code": {
                                        "type": "string",
                                        "example": "600001"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Hotel updated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/super_admin/hotel_lists": {
            "get": {
                "tags": [
                    "Hotel"
                ],
                "summary": "Hotel lists",
                "operationId": "bcda14d1e685a3d0493ef6c1815754bf",
                "responses": {
                    "200": {
                        "description": "Hotel lists",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "integer"
                                                    },
                                                    "name": {
                                                        "type": "string"
                                                    },
                                                    "city": {
                                                        "type": "string"
                                                    },
                                                    "phone": {
                                                        "type": "string"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        },
                                        "current_page": {
                                            "type": "integer"
                                        },
                                        "last_page": {
                                            "type": "integer"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/super_admin/hotel/{id}": {
            "get": {
                "tags": [
                    "Hotel"
                ],
                "summary": "Show hotel",
                "operationId": "2d514f7246aaa639f77941c831c40fe1",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "hotel retrieved successfully"
                    },
                    "400": {
                        "description": "hotel not found"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "Enter JWT Bearer token",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
